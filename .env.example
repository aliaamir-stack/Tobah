# Sportics 2025 Backend - Environment Variables

# This file contains the environment variables needed for the serverless backend.
# Copy this to your Vercel project environment variables.

# ====================
# RESEND EMAIL SERVICE
# ====================
# Sign up at https://resend.com and create an API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# ====================
# GOOGLE SHEETS API
# ====================
# 1. Go to Google Cloud Console
# 2. Create a new project or select existing
# 3. Enable Google Sheets API
# 4. Create a Service Account
# 5. Download JSON credentials and extract values below

GOOGLE_PROJECT_ID=your-project-id
GOOGLE_PRIVATE_KEY_ID=your-private-key-id
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=1234567890
GOOGLE_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com

# ====================
# GOOGLE SPREADSHEET
# ====================
# Create a new Google Sheet and share it with your service account email (GOOGLE_CLIENT_EMAIL)
# Copy the spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id

# ====================
# SPREADSHEET SETUP
# ====================
# Create a sheet named "Registrations" with these column headers in row 1:
# A: Timestamp
# B: Team Name
# C: Sport
# D: Fee
# E: Contact Name
# F: Contact Email
# G: Contact Phone
# H: Contact CNIC
# I: Player Count
# J: Players Info
# K: Payment Screenshot
# L: Status
